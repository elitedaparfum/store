# ── Backend (Railway) ──────────────────────────────────────────────────────────

# PostgreSQL connection string (provisioned automatically by Railway Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Random secret for signing session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Comma-separated list of allowed frontend origins (no trailing slash)
# e.g. your Vercel deployment URL + any custom domains
ALLOWED_ORIGINS=https://your-app.vercel.app,https://yourdomain.com

# Optional: comma-separated admin emails that always get admin rights on registration
ADMIN_EMAILS=owner@yourdomain.com

NODE_ENV=production


# ── Frontend (Vercel) ──────────────────────────────────────────────────────────

# Full URL of your Railway backend (no trailing slash)
VITE_API_URL=https://your-api.up.railway.app
